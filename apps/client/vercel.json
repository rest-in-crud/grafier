{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/p/:token",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Twitterbot|facebookexternalhit|Slackbot|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Googlebot|Bingbot).*"
        }
      ],
      "destination": "/api/og?token=:token"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
